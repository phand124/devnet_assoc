# ─────────────────────────────────────────────
# Python / uv
# ─────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
# uv.lock is INTENTIONALLY committed — do not add it here

# ─────────────────────────────────────────────
# Secrets and environment
# ─────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
vault_password
vault_pass.txt
.vault_pass
# Keep the example template
!.env.example

# ─────────────────────────────────────────────
# Ansible
# ─────────────────────────────────────────────
*.retry
.ansible/
ansible_collections/
# Generated from vault but never committed
group_vars/all/vault.yml
# Allow everything else in group_vars
!group_vars/
!group_vars/**

# ─────────────────────────────────────────────
# Containerlab
# ─────────────────────────────────────────────
# Runtime state directories (created by clab deploy)
clab-*/
# Topology binding files
*.clab.yml.bak
# Keep topology definitions themselves
!*.clab.yml

# ─────────────────────────────────────────────
# CML generated topologies
# ─────────────────────────────────────────────
# Auto-generated by clab-to-cml.py — regenerate don't commit
topologies/cml/*.yaml
# But keep the placeholder
!topologies/cml/.gitkeep

# ─────────────────────────────────────────────
# IOL / network images — never commit binaries
# ─────────────────────────────────────────────
*.bin
*.iso
*.iol
*.qcow2
*.vmdk
*.ova

# ─────────────────────────────────────────────
# pyATS / Genie
# ─────────────────────────────────────────────
archive/
pyats_logs/
*.log
*.xml
# Keep YANG and NETCONF XML files used as fixtures
!labs/*/yang_models/*.xml
!labs/*/fixtures/*.xml

# ─────────────────────────────────────────────
# Editor artifacts
# ─────────────────────────────────────────────
# Neovim swap/undo/backup files
*.swp
*.swo
*.swn
.netrwhist
# VSCodium
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ─────────────────────────────────────────────
# OS noise
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.directory

# ─────────────────────────────────────────────
# Misc output
# ─────────────────────────────────────────────
*.pcap
*.pcapng
output/
tmp/
